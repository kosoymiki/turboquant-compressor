{
  "name": "turboquant-compressor",
  "version": "4.5.2",
  "description": "TurboQuant v4.5.0 — Termux-first MCP server for compressed local vector search, context-pack retrieval, KV/cache analysis, and custom Adreno Rusticl/Freedreno/KGSL readiness forensics.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-wasm-assets.mjs",
    "postinstall": "bash scripts/install-driver-root.sh || true",
    "start": "node dist/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "smoke:api": "node scripts/smoke-public-api.mjs",
    "smoke:mcp": "node scripts/smoke-mcp.mjs",
    "smoke:numeric": "node scripts/smoke-numeric.mjs",
    "smoke:stdio": "node scripts/smoke-stdio.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "verify:termux": "node scripts/verify-termux-ready.mjs",
    "verify:adreno-opencl": "node scripts/verify-adreno-opencl.mjs",
    "verify:adreno-opencl:allow": "node scripts/verify-adreno-opencl.mjs --allow-unavailable",
    "verify:adreno-loader": "node scripts/verify-adreno-loader.mjs",
    "probe:opencl": "bash scripts/termux-opencl-probe.sh",
    "build:opencl": "bash scripts/build-opencl-native.sh",
    "install:driver-root": "bash scripts/install-driver-root.sh",
    "bench:opencl": "node scripts/benchmark-opencl-adreno.mjs",
    "bench:opencl:event-profile": "node scripts/collect-opencl-event-profile.mjs",
    "bench:opencl:controlled": "node scripts/run-opencl-controlled-lane.mjs",
    "bench:opencl:controlled:intercept": "node scripts/run-opencl-controlled-lane.mjs --external-intercept",
    "bench:opencl:controlled:sustained": "node scripts/run-opencl-controlled-lane.mjs --sustained",
    "build:opencl:intercept": "sh scripts/build-opencl-intercept.sh",
    "forensics:opencl-profiler-contract": "node scripts/collect-opencl-profiler-contract.mjs",
    "forensics:opencl-intercept-manifest": "node scripts/collect-opencl-intercept-manifest.mjs",
    "forensics:opencl-intercept-smoke": "node scripts/collect-opencl-intercept-smoke.mjs",
    "forensics:opencl-runtime-scheduler": "node scripts/collect-opencl-runtime-scheduler-contract.mjs",
    "forensics:opencl-inference-runtime": "node scripts/collect-opencl-inference-runtime-contract.mjs",
    "forensics:opencl-inference-runtime:refresh": "node scripts/collect-opencl-inference-runtime-contract.mjs --refresh",
    "forensics:opencl-paged-kv-prefix-cache": "node scripts/collect-opencl-paged-kv-prefix-cache-contract.mjs",
    "forensics:opencl-paged-kv-prefix-cache:refresh": "node scripts/collect-opencl-paged-kv-prefix-cache-contract.mjs --refresh",
    "forensics:precision-calibration-runtime": "node scripts/collect-precision-calibration-runtime-contract.mjs",
    "forensics:precision-calibration-runtime:refresh": "node scripts/collect-precision-calibration-runtime-contract.mjs --refresh",
    "forensics:gradient-verified-lsq-optimizer": "node scripts/collect-gradient-verified-lsq-optimizer-contract.mjs",
    "forensics:gradient-verified-lsq-optimizer:refresh": "node scripts/collect-gradient-verified-lsq-optimizer-contract.mjs --refresh",
    "forensics:distillation-for-quantization": "node scripts/collect-distillation-for-quantization-contract.mjs",
    "forensics:distillation-for-quantization:refresh": "node scripts/collect-distillation-for-quantization-contract.mjs --refresh",
    "forensics:hybrid-cpu-gpu-training-runtime": "node scripts/collect-hybrid-cpu-gpu-training-runtime-contract.mjs",
    "forensics:hybrid-cpu-gpu-training-runtime:refresh": "node scripts/collect-hybrid-cpu-gpu-training-runtime-contract.mjs --refresh",
    "forensics:full-qat-training-loop": "node scripts/collect-full-qat-training-loop-contract.mjs",
    "forensics:full-qat-training-loop:refresh": "node scripts/collect-full-qat-training-loop-contract.mjs --refresh",
    "verify:opencl-perf-regression": "node scripts/verify-opencl-performance-regression.mjs",
    "evidence:opencl-capabilities": "node scripts/generate-opencl-capability-evidence.mjs",
    "verify:opencl-claims": "node scripts/verify-opencl-claims.mjs",
    "verify:release-evidence": "node scripts/verify-release-evidence.mjs",
    "verify:mesa-patch-intelligence": "node scripts/verify-mesa-patch-intelligence.mjs",
    "forensics:mesa-stack": "node scripts/collect-mesa-stack-forensics.mjs",
    "forensics:mesa-offline": "node scripts/collect-offline-mesa-forensics.mjs",
    "forensics:mesa-adb": "node scripts/collect-adb-mesa-forensics.mjs",
    "forensics:agent-donors": "node scripts/ingest-agent-donor-corpus.mjs",
    "forensics:system-svm-donors": "node scripts/ingest-system-svm-donor-corpus.mjs",
    "forensics:frontier-donor-model": "node scripts/generate-frontier-donor-model.mjs",
    "forensics:p1-p3-backlog": "node scripts/generate-p1-p3-frontier-backlog.mjs",
    "verify:tests-determinism": "node scripts/verify-tests-determinism.mjs",
    "release:source": "rm -rf dist && npm run build && npm test -- --runInBand && npm run smoke:stdio && npm run verify:release && bash scripts/package-source.sh",
    "release:portable": "rm -rf dist && npm run build && npm test -- --runInBand && npm run smoke:stdio && npm run verify:release && bash scripts/package-portable.sh",
    "release:all": "npm run release:source && npm run release:portable && npm run verify:archives && npm run verify:artifact-parity",
    "package:source": "npm run verify:release && bash scripts/package-source.sh",
    "package:portable": "npm run verify:release && bash scripts/package-portable.sh",
    "package:release-slice": "npm run verify:release && python3 scripts/package-release-slice.py",
    "verify:archives": "node scripts/verify-archives.mjs",
    "verify:artifact-parity": "node scripts/verify-artifact-parity.mjs",
    "open:test:local": "node scripts/open-test-local.mjs",
    "open:test:local:save": "mkdir -p bench/results && TQ_OPEN_TEST_OUTPUT=bench/results/open-test-local-$(date +%Y%m%d-%H%M%S).json node scripts/open-test-local.mjs",
    "open:test:cost": "node scripts/open-test-cost.mjs"
  },
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js",
    "./tools/compress": "./dist/tools/compress.js",
    "./tools/search": "./dist/tools/search.js",
    "./core": "./dist/core/index.js",
    "./research": "./dist/research/index.js"
  },
  "keywords": [
    "vector",
    "compression",
    "quantization",
    "fwht",
    "mcp",
    "lloyd-max",
    "beta-distribution",
    "qjl",
    "johnson-lindenstrauss"
  ],
  "author": "",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0"
  }
}
