{
  "modes": [
    {
      "id": "termux_native",
      "description": "Native Termux control-plane, probes, pack inspection, and lightweight OpenCL/Vulkan tooling",
      "use_for": ["tq_adreno_cli", "vulkan_loader_probe", "mesa_artifact_inspection", "driver_pack_recovery", "adb_forensics_capture"],
      "do_not_claim": ["rusticl_ready", "turnip_ready", "full_driver_mesh_ready"],
      "toolchain": "Termux clang/clang++",
      "sysroot": "$PREFIX"
    },
    {
      "id": "mesa_kgsl_native_or_proot",
      "description": "Build Mesa Freedreno/Turnip/Rusticl with upstream-native kgsl route and reconstructed patches",
      "use_for": ["full_mesa_build", "turnip_vulkan", "rusticl_opencl", "freedreno_gl", "a7xx_a8xx_recovery"],
      "proof": ["clinfo", "vulkaninfo", "tq_value_dequant_parity", "tq_fused_attention_parity"],
      "toolchain": "clang/llvm or gcc/g++ depending on environment",
      "dependencies": ["meson", "ninja", "llvm-dev", "libclang-dev"]
    },
    {
      "id": "android_companion_service",
      "description": "App-private Vulkan/driver/service bridge via APK for namespace-isolated Android paths",
      "use_for": ["vulkan_compute_fallback", "command_buffer_bridge", "namespace_bypass", "driver_hot_swap_service"],
      "proof": ["service_handshake", "vulkan_probe", "command_buffer_execution", "parity"],
      "toolchain": "Android NDK / Gradle",
      "dependencies": ["Android SDK", "NDK r25+"]
    },
    {
      "id": "adrenotools_turnip",
      "description": "Turnip packaging and app-private hot-swap delivery via AdrenoTools-style loader",
      "use_for": ["vulkan_fallback_packaging", "app_private_driver", "packaging_research"],
      "proof": ["app_loads_driver", "vulkan_compute_shader_parity"],
      "toolchain": "NDK clang",
      "dependencies": ["AdrenoTools loader", "Turnip .so"]
    },
    {
      "id": "adb_forensics_replay",
      "description": "Device-truth capture path for KGSL, Vulkan, logs, bugreports, and runtime replay evidence",
      "use_for": ["kgsl_sysfs_capture", "vkjson_capture", "perfetto_capture", "driver_observability"],
      "proof": ["adb_connected", "device_truth_json_written", "kgsl_or_vkjson_evidence", "runtime_state_report"],
      "toolchain": "adb + host scripts",
      "dependencies": ["adb", "wireless_debugging_or_usb"]
    }
  ]
}
