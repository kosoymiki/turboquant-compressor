+/* TurboQuant: Real cutils binding via fake_dlopen for Rusticl on Android
+ * Donor: nihui/mesa-turnip-android-driver (dlfcn_nougat pattern)
+ * Required: resolves property_get/atrace symbols from system libcutils.so */
 #include <cutils/properties.h>
 #include <cutils/trace.h>
+#include <dlfcn.h>

-extern "C" {
+/* Use real libcutils when available (Android app context / Termux proot).
+ * Falls back to stubs if dlopen fails — safe for pure-Termux builds. */
+
+typedef int (*PFN_property_get)(const char *key, char *value, const char *default_value);
+typedef void (*PFN_atrace_begin_body)(const char *name);
+typedef void (*PFN_atrace_end_body)();
+typedef void (*PFN_atrace_init)();
+typedef uint64_t (*PFN_atrace_get_enabled_tags)();
+
+static void *cutils_lib = nullptr;
+static PFN_property_get real_property_get = nullptr;
+static PFN_atrace_begin_body real_atrace_begin_body = nullptr;
+static PFN_atrace_end_body real_atrace_end_body = nullptr;
+static PFN_atrace_init real_atrace_init = nullptr;
+static PFN_atrace_get_enabled_tags real_atrace_get_enabled_tags = nullptr;
+
+__attribute__((constructor))
+static void tq_cutils_init()
+{
+   cutils_lib = dlopen("libcutils.so", RTLD_NOW | RTLD_GLOBAL);
+   if (!cutils_lib) return;
+   real_property_get = (PFN_property_get)dlsym(cutils_lib, "property_get");
+   real_atrace_begin_body = (PFN_atrace_begin_body)dlsym(cutils_lib, "atrace_begin_body");
+   real_atrace_end_body = (PFN_atrace_end_body)dlsym(cutils_lib, "atrace_end_body");
+   real_atrace_init = (PFN_atrace_init)dlsym(cutils_lib, "atrace_init");
+   real_atrace_get_enabled_tags = (PFN_atrace_get_enabled_tags)dlsym(cutils_lib, "atrace_get_enabled_tags");
+}
+
+extern "C" {

 int
 property_get(const char *key, char *value, const char *default_value)
 {
-   return 0;
+   if (real_property_get) return real_property_get(key, value, default_value);
+   if (default_value && value) {
+      int len = 0;
+      while (default_value[len]) { value[len] = default_value[len]; len++; }
+      value[len] = 0;
+      return len;
+   }
+   if (value) value[0] = 0;
+   return 0;
 }

 void
-atrace_begin_body(const char * /*name*/)
+atrace_begin_body(const char *name)
 {
+   if (real_atrace_begin_body) real_atrace_begin_body(name);
 }

 void
 atrace_end_body()
 {
+   if (real_atrace_end_body) real_atrace_end_body();
 }

 void
 atrace_init()
 {
+   if (real_atrace_init) real_atrace_init();
 }

 uint64_t
 atrace_get_enabled_tags()
 {
-   return ATRACE_TAG_NOT_READY;
+   if (real_atrace_get_enabled_tags) return real_atrace_get_enabled_tags();
+   return 0; /* ATRACE_TAG_NOT_READY = 0 */
 }
+
 }
