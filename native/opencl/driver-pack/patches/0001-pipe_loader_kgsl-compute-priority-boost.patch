+/* KGSL ioctl defs for compute priority and performance */
+#define KGSL_IOC_TYPE 0x09
+#define IOCTL_KGSL_SETPROPERTY    _IOW(KGSL_IOC_TYPE, 0x32, struct kgsl_device_setproperty)
+#define IOCTL_KGSL_DEVICE_GETPROPERTY _IOWR(KGSL_IOC_TYPE, 0x02, struct kgsl_device_getproperty)
+
+#define KGSL_PROP_PWRCTRL        0x1E
+#define KGSL_PROP_DEVICE_INFO    0x01
+#define KGSL_CONTEXT_PRIORITY_HIGH 1
+
+struct kgsl_device_getproperty {
+   unsigned int type;
+   void *value;
+   size_t sizebytes;
+};
+
+struct kgsl_device_setproperty {
+   unsigned int type;
+   void *value;
+   size_t sizebytes;
+};
+
+/* Request high priority for compute context — reduces scheduling latency */
+static void
+kgsl_request_compute_priority(int fd)
+{
+   unsigned int priority = KGSL_CONTEXT_PRIORITY_HIGH;
+   struct kgsl_device_setproperty prop = {
+      .type = KGSL_PROP_PWRCTRL,
+      .value = &priority,
+      .sizebytes = sizeof(priority),
+   };
+   /* Best-effort: ignore failure (requires CAP or debug policy) */
+   ioctl(fd, IOCTL_KGSL_SETPROPERTY, &prop);
+}
+
+/* Force max GPU frequency for compute bursts */
+static void
+kgsl_boost_gpu_clocks(int fd)
+{
+   /* Write to /sys/class/kgsl/kgsl-3d0/devfreq/governor = performance
+    * Not available without root, but try sysfs hint */
+   (void)fd;
+   FILE *f = fopen("/sys/class/kgsl/kgsl-3d0/min_pwrlevel", "w");
+   if (f) { fprintf(f, "0"); fclose(f); }
+}
