{
  "id": "tq-adreno730-kgsl",
  "version": "0.1.0",
  "provider": "turboquant",
  "target_gpu": "Adreno 730 (A730v3)",
  "target_chip_id": "0x07030001",
  "build_source": "mesa-upstream 26.1.0-dev + kgsl patches",
  "layers": {
    "compute": {
      "tier": "RUSTICL_KGSL",
      "library_name": "libRusticlOpenCL.so.1",
      "backend": "freedreno/a6xx (A7XX template)",
      "pipe_loader": "pipe_loader_kgsl.c",
      "device_node": "/dev/kgsl-3d0",
      "features": [
        "cl_khr_fp16",
        "cl_khr_subgroups",
        "cl_khr_subgroup_shuffle",
        "cl_khr_subgroup_arithmetic"
      ],
      "subgroup_size": 128,
      "max_wg_size": 1024,
      "local_mem_kb": 32,
      "gmem_kb": 512,
      "compute_units": 2
    },
    "vulkan_backend": {
      "tier": "TURNIP_VK",
      "library_name": "libvulkan_freedreno.so",
      "api_version": "1.4.335",
      "backend": "turnip/kgsl",
      "device_node": "/dev/kgsl-3d0",
      "features": [
        "VK_KHR_shader_float16_int8",
        "VK_EXT_subgroup_size_control",
        "VK_KHR_cooperative_matrix"
      ],
      "role": "shader_compile_backend + vkcompute_fallback"
    }
  },
  "build": {
    "meson_options": "-Dgallium-rusticl=true -Dvulkan-drivers=freedreno -Dgallium-drivers=freedreno -Dfreedreno-kgsl=true -Dllvm=enabled -Dshared-llvm=disabled",
    "compiler": "clang-19",
    "linker": "lld",
    "static_libcxx": true,
    "strip": true
  },
  "validated": false,
  "sha256": {}
}
