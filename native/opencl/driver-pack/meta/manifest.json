{
  "id": "tq-adreno-a7xx-a8xx-kgsl",
  "version": "26.2.0-devel-tq-recovery1",
  "provider": "turboquant",
  "target_gpu": "Adreno a7xx-a8xx family",
  "target_chip_id": "family:a7xx-a8xx",
  "build_source": "mesa-upstream 26.2.0-devel + TurboQuant custom stack source state",
  "artifact_layout": {
    "root_contract": "unpacked archive root is the canonical TQ_DRIVER_ROOT",
    "entrypoints": {
      "env": "env.sh",
      "opencl_icd_dir": "layer1-compute",
      "vulkan_icd_manifest": "layer2-vulkan/freedreno_icd.aarch64.json",
      "kernel_dir": "kernels",
      "metadata_dir": "meta"
    },
    "files": [
      "env.sh",
      "layer1-compute/libRusticlOpenCL.so.1",
      "layer1-compute/libRusticlOpenCL.so.1.0.0",
      "layer1-compute/libRusticlOpenCL.so",
      "layer1-compute/libOpenCL.so.1",
      "layer1-compute/rusticl.icd",
      "layer1-compute/clc/spirv-mesa3d-.spv",
      "layer1-compute/clc/spirv64-mesa3d-.spv",
      "layer2-vulkan/libvulkan_freedreno.so",
      "layer2-vulkan/freedreno_icd.aarch64.json",
      "meta/manifest.json",
      "meta/dependencies.txt"
    ]
  },
  "layers": {
    "compute": {
      "tier": "RUSTICL_KGSL",
      "library_name": "libRusticlOpenCL.so.1",
      "backend": "freedreno/rusticl via gallium on kgsl",
      "pipe_loader": "upstream pipe_loader_kgsl.c / freedreno kgsl route",
      "device_node": "/dev/kgsl-3d0",
      "features": [
        "cl_khr_fp16",
        "cl_khr_subgroups",
        "cl_khr_subgroup_shuffle",
        "cl_khr_subgroup_arithmetic"
      ],
      "subgroup_size": "a7xx:128-when-exposed,a8xx:64x2",
      "max_wg_size": 1024,
      "local_mem_kb": 32,
      "gmem_kb": 512,
      "compute_units": "device-dependent"
    },
    "vulkan_backend": {
      "tier": "TURNIP_VK",
      "library_name": "libvulkan_freedreno.so",
      "api_version": "1.4.335",
      "backend": "turnip/kgsl",
      "device_node": "/dev/kgsl-3d0",
      "features": [
        "VK_KHR_shader_float16_int8",
        "VK_EXT_subgroup_size_control",
        "VK_KHR_cooperative_matrix"
      ],
      "role": "shader_compile_backend + vkcompute_fallback + command stream evidence path"
    }
  },
  "build": {
    "meson_options": "-Dplatforms=android -Dplatform-sdk-version=34 -Dandroid-stub=true -Dandroid-libbacktrace=disabled -Dgallium-rusticl=true -Dgallium-rusticl-enable-drivers=freedreno -Dvulkan-drivers=freedreno -Dgallium-drivers=freedreno -Dfreedreno-kmds=kgsl -Dllvm=enabled -Dshared-llvm=enabled -Dstatic-libclc=all -Dbuildtype=debugoptimized -Dstrip=false",
    "compiler": "llvm/clang (Termux canonical toolchain)",
    "linker": "lld",
    "static_libcxx": false,
    "strip": false,
    "mesa_source": "/data/data/com.termux/files/home/mesa-upstream-26.2-devel",
    "build_dir": "/data/data/com.termux/files/home/.cache/turboquant/mesa-build-android34",
    "install_prefix": "/data/data/com.termux/files/home/tmp_turboquant/native/opencl/driver-root",
    "sdk_level": "34",
    "android_target": "aarch64-linux-android34",
    "android_target_triple": "aarch64-linux-android",
    "llvm_state": "enabled",
    "rusticl_enable_drivers": "freedreno",
    "static_libclc": "all",
    "toolchain_contract": {
      "clang": "/data/data/com.termux/files/usr/bin/clang",
      "clangxx": "/data/data/com.termux/files/usr/bin/clang++",
      "llvm_config": "/data/data/com.termux/files/usr/bin/llvm-config",
      "llvm_spirv": "/data/data/com.termux/files/usr/bin/llvm-spirv",
      "spirv_link": "/data/data/com.termux/files/usr/bin/spirv-link",
      "spirv_val": "/data/data/com.termux/files/usr/bin/spirv-val",
      "libclc_path": "/data/data/com.termux/files/usr/share/clc",
      "device_libclc_path": "/data/local/tmp/tq-rusticl/clc"
    },
    "rusticl_runtime_env": {
      "RUSTICL_ENABLE": "freedreno",
      "MESA_SHADER_CACHE_DIR": "/data/data/com.termux/files/home/.cache/turboquant-rusticl"
    }
  },
  "validated": true,
  "sha256": {
    "libRusticlOpenCL.so.1": "60cabd59d8c904e11328b658ba6aba08da089f57222beddecdfbeac0e1649f00",
    "libRusticlOpenCL.so.1.0.0": "60cabd59d8c904e11328b658ba6aba08da089f57222beddecdfbeac0e1649f00",
    "libvulkan_freedreno.so": "fb98e40fd3085df4bfd38c4a01dc2168d151708f35e13694f66686a1d4e40446"
  },
  "policy": {
    "production_route": "custom_driver_stack_only",
    "vendor_opencl_primary": false,
    "generic_opencl_allowed": false,
    "notes": [
      "This manifest describes the assembled custom driver runtime.",
      "Mesa 26.2+ already exposes freedreno-kmds=kgsl upstream; old freedreno-kgsl=true guidance is stale.",
      "Binary release contract is TQ_DRIVER_ROOT-first with native/opencl/driver-root as the canonical assembled stack.",
      "Per-device subgroup and workgroup tuning must be revalidated on real A7xx/A8xx hardware.",
      "Treat A7xx as wave128-capable when the stack explicitly exposes it; treat A8xx as dual wave64."
    ]
  },
  "pack_date": "2026-05-22T17:47:41Z"
}